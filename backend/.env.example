# ============================================
# Khetalpura Dairy - Environment Configuration
# ============================================

# Server
PORT=5000
NODE_ENV=development

# Local MongoDB (runs on admin's laptop)
MONGODB_URI=mongodb+srv://gauttamaddarssh_db_user:ZnROXhviHskqfnNQ@cluster1.3lxjl1a.mongodb.net/?appName=Cluster1

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=90d

# MSG91 OTP Service (for customer phone verification)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_FLOW_ID=your_msg91_flow_id
MSG91_SENDER_ID=KHETDP

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
# Set to true for development (accepts any 6-digit OTP like 123456)
MOCK_OTP=true

# Local File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Backup Configuration
BACKUP_DIR=./backups
BACKUP_CRON=0 2 * * *
# Keep backups for 30 days
BACKUP_RETENTION_DAYS=30

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=5
